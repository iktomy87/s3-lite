# ────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores
# cp .env.example .env
# ────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────
POSTGRES_DB=s3lite
POSTGRES_USER=s3lite
POSTGRES_PASSWORD=changeme_strong_password

# ── Backend ─────────────────────────────────────
# Clave secreta para firmar los JWT (mín. 32 caracteres)
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_256_bits_en_produccion
JWT_EXPIRATION_MS=86400000

# ── CORS ────────────────────────────────────────
# Origen(es) que el backend acepta (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost

# ── Frontend ────────────────────────────────────
# URL de la API que el navegador usará (debe ser accesible desde el cliente)
REACT_APP_API_URL=http://localhost:8080/api
